# ==============================================================================
# Instagram Multi-Account Publisher Environment Configuration Template
# ==============================================================================

# Project Name
PROJECT_NAME="Instagram Multi-Account Publisher"

# PostgreSQL Configuration
# Use "db" instead of "localhost" when running within docker-compose network
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ig_publisher

# Redis & Celery Configuration
# Use "redis" instead of "localhost" when running within docker-compose network
REDIS_URL=redis://localhost:6379/0

# JWT Security
JWT_SECRET_KEY=supersecretjwtkeyfordevelopmentpurposeonlychangeinproduction
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cryptography Token Encryption Key
# Generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=vA3Z6f_y-G1L6XQ9sH02Z_XJ0_pU48c-7Fv0v22119c=

# CrewAI & LLM Configuration (Required for AI Agents)
# Get your key from: https://platform.openai.com/
OPENAI_API_KEY=sk-placeholder-key-for-crewai-agent
OPENAI_MODEL_NAME=gpt-4o-mini

# Public URL Prefix
# Instagram Graph API needs to pull images from a public endpoint.
# In local development, set this to serve files through FastAPI or ngrok tunnel.
PUBLIC_URL_PREFIX=http://localhost:8000/static/uploads

# Default Admin Seed Credentials (Created on app startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
